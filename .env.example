BOT_TOKEN=your-telegram-bot-token
NVIDIA_API_KEY=your-provider-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
KIMI_API_KEY=your-kimi-api-key
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
IMAGE_MODEL=black-forest-labs/flux.1-dev
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2
KIMI_MODEL=moonshotai/kimi-k2.5
LOG_LEVEL=INFO
# Optional: set only if you need a custom public URL instead of Render's default URL.
PUBLIC_BASE_URL=
# Optional: override the Telegram mini app URL used by the bot menu button.
# Replace only if your final GitHub Pages URL differs from the default below.
# Default: https://ygirma315-cell.github.io/jo-ai/
MINIAPP_URL=https://ygirma315-cell.github.io/jo-ai/
# Optional: override the backend URL appended to the mini app as ?api_base=...
# Replace only if your real public Render backend URL differs from miniapp/config.js.
MINIAPP_API_BASE=
# Optional: extra CORS origins, comma-separated. Leave blank to use Pages/Render/local defaults.
ALLOWED_ORIGINS=
# Optional: override only if you manually manage Telegram webhook routing.
# Most setups should leave this empty and let Render/PUBLIC_BASE_URL build it automatically.
TELEGRAM_WEBHOOK_URL=
# Optional: reuse the secret from Render for local webhook testing.
TELEGRAM_WEBHOOK_SECRET=
