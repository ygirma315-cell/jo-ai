{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "JO AI: Debug Backend",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "JO AI: Debug Setup Validation",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/validate_setup.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
